# Mock mode: tools work locally without ONDC registration
ONDC_MOCK=true
ONDC_ENV=staging                      # staging | preprod | prod

# From registry onboarding (leave blank until whitelisted)
ONDC_SUBSCRIBER_ID=ondc.kaushalstack.com
