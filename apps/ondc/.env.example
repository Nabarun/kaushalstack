ONDC_UNIQUE_KEY_ID=
ONDC_SIGNING_PRIVATE_KEY=
ONDC_ENC_PRIVATE_KEY=
ONDC_PUBLIC_KEY=                      # ONDC's env-specific public key

# Business profile used for lead scoring
BUSINESS_GPS=12.9416,77.7400          # Panathur, Bengaluru
BUSINESS_KEYWORDS=physiotherapy,rehab,sports injury
